const express = require('express');
const router = express.Router();
const rateLimit = require('express-rate-limit');
const multer = require('multer');
const xlsx = require('xlsx');
// Import the new auth middleware (adjust path if needed)
const { isAuthenticated, requireRole } = require('../middleware/auth');
const User = require('../models/User');
const Order = require('../models/Order');
const Product = require('../models/Product');
const { sendOrderShippedEmail, sendOrderDeliveredEmail } = require('../utils/mailjet');

// Apply rate limiting to admin routes
const adminRateLimit = rateLimit({ 
  windowMs: 15 * 60 * 1000, // 15 minutes
  max: 50, // limit each IP to 50 requests per windowMs
  message: 'Too many requests from this IP, please try again later.'
});

// Excel upload configuration
const excelUpload = multer({
  storage: multer.memoryStorage(),
  limits: { fileSize: 10 * 1024 * 1024 },
  fileFilter: (req, file, cb) => {
    const allowedTypes = ['.xlsx', '.xls', '.csv'];
    const ext = file.originalname.toLowerCase().substring(file.originalname.lastIndexOf('.'));
    if (allowedTypes.includes(ext)) {
      cb(null, true);
    } else {
      cb(new Error('Only Excel (.xlsx, .xls) and CSV files are allowed'));
    }
  }
});

// Apply auth, admin, and rate limiting middleware to all routes in this file
router.use(adminRateLimit);
router.use(isAuthenticated, requireRole('admin'));

// @route   GET /api/admin/stats
// @desc    Get admin dashboard stats
// @access  Private/Admin
router.get('/stats', async (req, res) => {
  try {
    const totalOrders = await Order.countDocuments({});
    const totalUsers = await User.countDocuments({}); 
    
    // --- FIX: Use status from Order model ---
    const pendingOrders = await Order.countDocuments({ 
        status: 'placed' // Matching the Order.js model enum
    });

    const revenueResult = await Order.aggregate([
      {
        // --- FIX: Use status from Order model ---
        $match: { status: { $in: ['paid', 'shipped', 'delivered'] } } // Treat these as revenue-recognized statuses
      },
      {
        $group: {
          _id: null,
           // --- FIX: Use 'total' from Order model ---
          totalRevenue: { $sum: '$total' }
        }
      }
    ]);

    const totalRevenue = revenueResult.length > 0 ? revenueResult[0].totalRevenue : 0;

    res.json({
      totalOrders,
      totalUsers,
      totalRevenue,
      pendingOrders
    });
  } catch (err) {
    console.error('Admin stats error:', err);
    const errorMessage = process.env.NODE_ENV === 'development' 
      ? err.message 
      : 'Internal server error';
    res.status(500).json({ 
      message: 'Server Error',
      error: errorMessage,
      ...(process.env.NODE_ENV === 'development' && { stack: err.stack })
    });
  }
});

// @route   GET /api/admin/orders
// @desc    Get all orders for admin (paginated)
// @access  Private/Admin
router.get('/orders', async (req, res) => {
  try {
    const page = parseInt(req.query.page) || 1;
    const limit = parseInt(req.query.limit) || 10;
    const skip = (page - 1) * limit;
    const limitQuery = parseInt(req.query.limit) || 0; // For dashboard recent orders
    const statusFilter = req.query.status; // <-- Get status filter

    // Build the filter object
    const filter = {};
    if (statusFilter) {
        filter.status = statusFilter; // Add status to the MongoDB query filter
    }

    let query = Order.find(filter) // <-- Apply the filter
      .populate('user', 'name')
      .sort({ createdAt: -1 });

    if (limitQuery > 0) {
        query = query.limit(limitQuery); // For ?limit=5
    } else {
        query = query.skip(skip).limit(limit); // For paginated view
    }

    // Use the same filter for counting documents
    const totalOrders = await Order.countDocuments(filter); // <-- Count with filter
    const orders = await query;

    const formattedOrders = orders.map(order => ({
        date: order.createdAt.toLocaleDateString(),
        id: order._id,
        customer: order.user ? order.user.name : (order.billing.name || 'Guest User'),
        total: order.total,
        status: order.status
    }));

    res.json({
        data: formattedOrders,
        pagination: {
            page,
            limit,
            totalPages: Math.ceil(totalOrders / limit),
            total: totalOrders
        }
    });
  } catch (err) {
    console.error('Admin orders error:', err);
    const errorMessage = process.env.NODE_ENV === 'development' 
      ? err.message 
      : 'Internal server error';
    res.status(500).json({ 
      message: 'Server Error',
      error: errorMessage,
      ...(process.env.NODE_ENV === 'development' && { stack: err.stack })
    });
  }
});

// @route   PUT /api/admin/orders/:id/status
// @desc    Update order status
// @access  Private/Admin
router.put('/orders/:id/status', async (req, res) => {
    try {
        const { status, trackingNumber, carrierName } = req.body;
        // Expanded valid statuses
        const validStatuses = ['placed', 'processing', 'paid', 'failed', 'shipped', 'delivered', 'cancelled', 'refunded']; 
        if (!status || !validStatuses.includes(status)) {
            return res.status(400).json({ message: 'Invalid status' });
        }

        const order = await Order.findByIdAndUpdate(req.params.id, { status }, { new: true }).populate('user');
        if (!order) {
            return res.status(404).json({ message: 'Order not found' });
        }

        const itemListHtml = order.items.map(item => `<li>${item.name} (x${item.qty})</li>`).join('');

        if (status === 'shipped') {
            const estimatedDelivery = new Date();
            estimatedDelivery.setDate(estimatedDelivery.getDate() + 3); // 3 days from now
            sendOrderShippedEmail({
                toEmail: order.billing.email,
                userName: order.billing.name,
                orderId: order._id.toString(),
                itemList: `<ul>${itemListHtml}</ul>`,
                trackingNumber: trackingNumber || 'Not available',
                carrierName: carrierName || 'Courier',
                estimatedDeliveryDate: estimatedDelivery.toDateString(),
                trackingLink: `${process.env.WEBSITE_URL}/track-order.html?id=${order._id.toString()}`,
                paymentAmount: `GHS ${(order.total || 0).toFixed(2)}`
            }).catch(err => console.error('Failed to send order shipped email:', err));
        } else if (status === 'delivered') {
            sendOrderDeliveredEmail({
                toEmail: order.billing.email,
                userName: order.billing.name,
                orderId: order._id.toString(),
                itemList: `<ul>${itemListHtml}</ul>`,
                deliveryDate: new Date().toDateString(),
                feedbackLink: `${process.env.WEBSITE_URL}/feedback.html?orderId=${order._id.toString()}`
            }).catch(err => console.error('Failed to send order delivered email:', err));
        }

        res.json(order);
    } catch (err) {
        console.error('Admin update order status error:', err);
        const errorMessage = process.env.NODE_ENV === 'development' 
          ? err.message 
          : 'Internal server error';
        res.status(500).json({ 
          message: 'Server Error',
          error: errorMessage,
          ...(process.env.NODE_ENV === 'development' && { stack: err.stack })
        });
    }
});


// @route   GET /api/admin/users
// @desc    Get all users for admin
// @access  Private/Admin
router.get('/users', async (req, res) => {
  try {
    const page = parseInt(req.query.page) || 1;
    const limit = parseInt(req.query.limit) || 15;
    const skip = (page - 1) * limit;

    // --- FIX for User Filter ---
    const filter = {};
    if (req.query.role) {
      filter.role = req.query.role;
    }
    // --- End Fix ---

    const totalUsers = await User.countDocuments(filter);
    const users = await User.find(filter)
      .select('-passwordHash') // Use '-passwordHash' to match your model
      .sort({ createdAt: -1 })
      .skip(skip)
      .limit(limit);
    
    // Add 'isActive' field to user model if it's not there
    // For now, assuming it exists or defaulting
    const formattedUsers = users.map(user => ({
    _id: user._id,
    name: user.name,
    email: user.email,
    role: user.role,
    createdAt: user.createdAt,
    isActive: user.isActive !== false, // Default to true if field is missing
    isEmailVerified: user.emailVerified, // Match model
  }));


    res.json({
        data: formattedUsers,
        pagination: {
            page,
            limit,
            totalPages: Math.ceil(totalUsers / limit),
            total: totalUsers
        }
    });
  } catch (err) {
    console.error('Admin orders error:', err);
    const errorMessage = process.env.NODE_ENV === 'development' 
      ? err.message 
      : 'Internal server error';
    res.status(500).json({ 
      message: 'Server Error',
      error: errorMessage,
      ...(process.env.NODE_ENV === 'development' && { stack: err.stack })
    });
  }
});

// @route   PATCH /api/admin/users/:id/role
// @desc    Update user role
// @access  Private/Admin
router.patch('/users/:id/role', async (req, res) => {
    try {
        const { role } = req.body;
        const validRoles = ['customer', 'admin']; // Match your roles
        if (!role || !validRoles.includes(role)) {
            return res.status(400).json({ message: 'Invalid role specified' });
        }

        const user = await User.findByIdAndUpdate(req.params.id, { role }, { new: true }).select('-passwordHash'); // Exclude password
        if (!user) {
            return res.status(404).json({ message: 'User not found' });
        }
        res.json(user);
    } catch (err) {
        console.error('Admin update role error:', err);
        // Handle potential CastError if ID format is invalid
        if (err.kind === 'ObjectId') {
             return res.status(404).json({ message: 'User not found' });
        }
        const errorMessage = process.env.NODE_ENV === 'development' 
          ? err.message 
          : 'Internal server error';
        res.status(500).json({ 
          message: 'Server Error',
          error: errorMessage,
          ...(process.env.NODE_ENV === 'development' && { stack: err.stack })
        });
    }
});

// @route   PATCH /api/admin/users/:id/status
// @desc    Activate/Deactivate user
// @access  Private/Admin
router.patch('/users/:id/status', async (req, res) => {
    try {
        const { isActive } = req.body;
        if (typeof isActive !== 'boolean') {
            return res.status(400).json({ message: 'Invalid status value. Must be true or false.' });
        }

        // Ensure admin cannot deactivate themselves (optional but recommended)
        const userIdStr = String(req.user._id || req.user.id);
        const paramIdStr = String(req.params.id);
        if (userIdStr === paramIdStr && !isActive) {
             return res.status(400).json({ message: 'Admin cannot deactivate themselves.' });
        }
        
        // Add { isActive: { type: Boolean, default: true } } to your user.js model!
        const user = await User.findByIdAndUpdate(req.params.id, { isActive }, { new: true }).select('-passwordHash'); // Exclude password
        if (!user) {
            return res.status(404).json({ message: 'User not found' });
        }
        res.json(user);
    } catch (err) {
        console.error('Admin update status error:', err);
         if (err.kind === 'ObjectId') {
             return res.status(404).json({ message: 'User not found' });
        }
        const errorMessage = process.env.NODE_ENV === 'development' 
          ? err.message 
          : 'Internal server error';
        res.status(500).json({ 
          message: 'Server Error',
          error: errorMessage,
          ...(process.env.NODE_ENV === 'development' && { stack: err.stack })
        });
    }
});

// @route   POST /api/admin/report
// @desc    Generate a sales report
// @access  Private/Admin
router.post('/report', async (req, res) => {
    const { startDate, endDate } = req.body;

    if (!startDate || !endDate) {
        return res.status(400).json({ message: 'Please provide start and end dates' });
    }

    try {
        const orders = await Order.find({
            createdAt: { 
                $gte: new Date(startDate), 
                $lte: new Date(new Date(endDate).setHours(23, 59, 59, 999)) // Ensure full day
            },
            // --- FIX: Use status from Order model ---
            status: { $in: ['paid', 'shipped', 'delivered'] }
        });

        const totalOrders = orders.length;
         // --- FIX: Use 'total' from Order model ---
        const totalRevenue = orders.reduce((acc, order) => acc + order.total, 0);
        const avgOrderValue = totalOrders > 0 ? (totalRevenue / totalOrders) : 0;

        res.json({
            period: `${new Date(startDate).toLocaleDateString()} to ${new Date(endDate).toLocaleDateString()}`,
            totalOrders,
            totalRevenue,
            avgOrderValue
        });

    } catch (err) {
        console.error('Admin report error:', err);
        const errorMessage = process.env.NODE_ENV === 'development' 
          ? err.message 
          : 'Internal server error';
        res.status(500).json({ 
          message: 'Server Error',
          error: errorMessage,
          ...(process.env.NODE_ENV === 'development' && { stack: err.stack })
        });
    }
});


