{
  "name": "ipmc-kart",
  "version": "1.0.0",
  "description": "IPMC Kart E-commerce Platform",
  "main": "server.js",
  "scripts": {
    "test": "jest --detectOpenHandles --forceExit --runInBand",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "start": "node server.js",
    "test:e2e": "cross-env NODE_ENV=test node server.js",
    "minify-js": "node scripts/minify.js",
    "build:hash": "node scripts/build-hash.js",
    "bundle:homepage": "node scripts/bundle-homepage-scripts.js",
    "precompress": "node scripts/precompress-assets.js",
    "build:all": "npm run bundle:homepage && npm run precompress"
  },
  "dependencies": {
    "@capacitor/android": "^8.1.0",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/camera": "^8.0.1",
    "@capacitor/cli": "^8.1.0",
    "@capacitor/core": "^8.1.0",
    "@capacitor/device": "^8.0.1",
    "@capacitor/ios": "^8.1.0",
    "@capacitor/network": "^8.0.1",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/push-notifications": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.1",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "body-parser": "^2.2.0",
    "bullmq": "^5.66.5",
    "cheerio": "^1.2.0",
    "compression": "^1.8.1",
    "connect-mongo": "^5.1.0",
    "connect-redis": "^9.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.1",
    "express-rate-limit": "^8.2.1",
    "express-session": "^1.18.2",
    "express-static-gzip": "^3.0.0",
    "express-validator": "^7.2.1",
    "git-filter-repo": "^0.0.30",
    "helmet": "^8.1.0",
    "ioredis": "^5.9.0",
    "jsonwebtoken": "^9.0.2",
    "method-override": "^3.0.0",
    "mongoose": "^8.18.0",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "node-cron": "^4.2.1",
    "node-mailjet": "^6.0.11",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-local": "^1.0.0",
    "paystack": "^2.0.1",
    "redis": "^5.10.0",
    "slugify": "^1.6.6",
    "validator": "^13.15.15",
    "winston": "^3.18.3",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@testsprite/testsprite-mcp": "^0.0.16",
    "cross-env": "^7.0.3",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^10.3.0",
    "supertest": "^6.3.3",
    "terser": "^5.31.1"
  },
  "jest": {
    "testEnvironment": "node",
    "coveragePathIgnorePatterns": [
      "/node_modules/"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/jest.setup.js"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/__tests__/[^.]*\\.js$"
    ]
  }
}
