NODE_ENV=production
PORT=4040
MONGO_URL=mongodb+srv://username:password@cluster.mongodb.net/databaseName

# JWT (MUST be a cryptographically secure random string, min 32 characters)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# Cookies
COOKIE_SECURE=true
COOKIE_SAMESITE=lax

# Frontend + redirects
FRONTEND_URL=https://ipmckart.com
POST_LOGIN_REDIRECT=https://ipmckart.com/dashboard.html

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://ipmckart.com/api/auth/google/callback

# Facebook OAuth (if you'll use it)
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_CALLBACK_URL=https://ipmckart.com/api/auth/facebook/callback

# Redis Cache Configuration
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_MAX_RETRIES=3

# Mailjet
MAILJET_API_KEY=
MAILJET_SECRET_KEY=
EMAIL_SENDER=shop@ipmckart.com
EMAIL_SENDER_NAME=IPMC Kart
WEBSITE_URL=https://ipmckart.com

# Paystack
PAYSTACK_SECRET_KEY=

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
